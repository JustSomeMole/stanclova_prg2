<Window x:Class="stanclova_rgb_aplikace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:stanclova_rgb_aplikace"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Rectangle x:Name="block" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="74,59,0,0" Width="298" Height="349" Stroke="Black"/>
        <Label Content="RGB míchátko" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="400,32,0,0" Width="290" Height="57" FontSize="36"/>
        <Label Content="Red" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="408,107,0,0" Width="63" Height="38" FontSize="16" Background="Red" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <TextBox x:Name="txtRed" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="483,113,0,0" Width="142" Height="24" TextChanged="txtRed_TextChanged"/>
        <Slider x:Name="sliderRed" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="408,155,0,0" Width="282" Height="17" Minimum="0" Maximum="255" ValueChanged="sliderRed_ValueChanged"/>
        <Label Content="Green" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="408,194,0,0" Width="63" Height="36" FontSize="16" Background="#FF00FF10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <TextBox x:Name="txtGreen" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="483,200,0,0" Width="142" Height="23" TextChanged="txtGreen_TextChanged"/>
        <Slider x:Name="sliderGreen" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="408,243,0,0" Width="282" Height="17" Minimum="0" Maximum="255" ValueChanged="sliderGreen_ValueChanged"/>
        <Label Content="Blue" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="408,283,0,0" Width="63" Height="37" FontSize="16" Background="#FF0010FF" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <TextBox x:Name="txtBlue" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="483,290,0,0" Width="142" Height="22" TextChanged="txtBlue_TextChanged"/>
        <Slider x:Name="sliderBlue" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="408,331,0,0" Width="282" Height="17" Minimum="0" Maximum="255" ValueChanged="sliderBlue_ValueChanged"/>
        <Label x:Name="txtHex" Content="#000000" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="408,377,0,0" Width="207" Height="31"/>
    </Grid>
</Window>
